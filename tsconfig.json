{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext", // обязательно при NodeNext
    "moduleResolution": "NodeNext", // поддержка ESM + .ts/.js файлов
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "verbatimModuleSyntax": true // оставь true для корректной генерации import/export
  },
  "include": ["tests/**/*.ts", "playwright.config.ts"]
}
